generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password_hash String
  name          String
  phone         String?
  address       String?
  role          Role     @default(user)
  pets          Pet[]
  logs          ActivityLog[]
  notifications Notification[]
  sessions      UserSession[]
  createdAt     DateTime @default(now())
}

enum Role {
  user
  hospital
  admin
}

model Pet {
  id           String   @id @default(cuid())
  petId        String   @unique
  owner        User     @relation(fields: [ownerId], references: [id])
  ownerId      String
  name         String
  type         String
  breed        String?
  age          Int?
  weight       Float?
  gender       String?
  image        String?  @db.LongText
  medicalNotes String?
  appointments Appointment[]
  vaccinations Vaccination[]
  createdAt    DateTime @default(now())
}

enum HospitalType {
  hospital
  clinic
}

model Hospital {
  id          String   @id @default(cuid())
  name        String
  type        HospitalType @default(hospital)
  address     String?
  phone       String?
  latitude    Float?
  longitude   Float?
  openingTime String?
  closingTime String?
  isOpen24h   Boolean  @default(false)
  description String?
  rating      Float? 
  image       String?  @db.LongText
  mapUrl      String?
  appointments Appointment[]
  vaccinations Vaccination[]
}

model Appointment {
  id          String   @id @default(cuid())
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  petId       String
  hospital    Hospital @relation(fields: [hospitalId], references: [id])
  hospitalId  String
  date        String
  time        String
  status      Status   @default(pending)
  reason      String?
  records     MedicalRecord[]
  createdAt   DateTime @default(now())
}

enum Status {
  pending
  confirmed
  completed
  cancelled
}

model Vaccination {
  id          String   @id @default(cuid())
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  petId       String
  vaccineName String
  date        String
  nextDate    String
  hospital    Hospital @relation(fields: [hospitalId], references: [id])
  hospitalId  String
  createdAt   DateTime @default(now())
}

model MedicalRecord {
  id           String   @id @default(cuid())
  appointment  Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentId String
  symptoms     String
  diagnosis    String
  treatment    String
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  admin     User     @relation(fields: [adminId], references: [id])
  adminId   String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginAt      DateTime @default(now())
  lastActiveAt DateTime @default(now())
  logoutAt     DateTime?
  ipAddress    String?
  userAgent    String?
  
  @@index([userId])
  @@index([lastActiveAt])
}
